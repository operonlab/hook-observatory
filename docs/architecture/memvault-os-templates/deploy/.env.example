# memvault-os standalone deployment — environment variables
# Copy this file to .env and fill in the required values.
#
# Lines starting with # are comments.
# Lines ending with := provide default values and usually don't need editing.

# ==============================================================================
# REQUIRED — must set these before starting
# ==============================================================================

# Admin API token — all API calls must include:
#   Authorization: Bearer <MEMVAULT_OS_TOKEN>
# Generate a strong token: openssl rand -hex 32
MEMVAULT_OS_TOKEN=

# PostgreSQL password (choose a strong random password)
POSTGRES_PASSWORD=

# ==============================================================================
# PostgreSQL
# ==============================================================================

POSTGRES_USER=memvault
POSTGRES_DB=memvault_db
POSTGRES_PORT=5432

# If you override DATABASE_URL directly (e.g., external managed PG),
# it takes precedence over the POSTGRES_* vars above.
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname

# ==============================================================================
# Redis
# ==============================================================================

REDIS_PORT=6379
# Optional Redis password (leave empty for no auth)
REDIS_PASSWORD=
# Max memory limit for Redis (allkeys-lru eviction)
REDIS_MAX_MEMORY=256mb

# If you override REDIS_URL directly, it takes precedence.
# REDIS_URL=redis://:password@host:6379/0

# ==============================================================================
# memvault-os application
# ==============================================================================

# Docker image to run
MEMVAULT_OS_IMAGE=ghcr.io/joneshong/memvault-os:latest

# Port exposed on host
MEMVAULT_OS_PORT=10090

# Space identifier for the default user (single-space standalone mode)
MEMVAULT_OS_SPACE_ID=default

# ==============================================================================
# Embedding provider
# Choose one of: openai | ollama | azure_openai
# ==============================================================================

EMBED_PROVIDER=openai

# --- OpenAI (default) ---
# EMBED_MODEL must produce 1024-dimension vectors to match the DB schema.
# text-embedding-3-small supports arbitrary dimensions via dimensions= param.
EMBED_MODEL=text-embedding-3-small
EMBED_API_KEY=

# --- Ollama (local, no API key needed) ---
# Set EMBED_PROVIDER=ollama and point to your Ollama instance.
# Recommended model: nomic-embed-text (768d — schema must be adjusted) or
#                    qwen3-embedding (1024d — matches schema exactly).
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# ==============================================================================
# LLM provider (for synthesis / dream pipeline / knowledge lint)
# ==============================================================================

LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_API_KEY=

# Alternative: Anthropic
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-3-5-haiku-20241022
# LLM_API_KEY=

# ==============================================================================
# Optional: S3-compatible storage (for cold / frozen tier)
# Leave blank to disable cold/frozen archival. Core recall still works.
# ==============================================================================

S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_FROZEN=memvault-frozen
S3_BUCKET_ARCHIVE=memvault-archive

# ==============================================================================
# Observability (optional)
# ==============================================================================

# OTLP endpoint for traces / metrics (OpenTelemetry)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=memvault-os

# Log level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
