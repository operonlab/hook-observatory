{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Workshop Assistant",
  "identifier": "com.joneshong.workshop-fairy",
  "version": "0.1.0",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Workshop Assistant",
        "width": 300,
        "height": 400,
        "resizable": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": true,
        "center": false,
        "x": 100,
        "y": 100
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": true,
      "tooltip": "Workshop Assistant"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "dmg": {
        "appName": "Workshop Assistant"
      },
      "minimumSystemVersion": "10.15"
    }
  }
}
