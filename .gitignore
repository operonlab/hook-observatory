__pycache__/
*.py[cod]
*.egg-info/
.venv/
dist/

# Node
node_modules/
.turbo/

# Environment
.env
.env.*
!.env.example

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Backup
backup/

# Build
workbench/dist/
libs/typescript/dist/
stations/*/dist/

# Logs
*.log

# Claude
CLAUDE.local.md
.claude/settings.local.json
dotclaude

# Playwright CLI session artifacts
.playwright-cli/

# Worktrees
.worktrees/
.claude/worktrees/

# OMX runtime (logs + state snapshots)
.omx/

# Checkpoints (session state snapshots)
.checkpoints/

# Data (runtime state, not source code)
data/

# Outputs (skill/script working artifacts, not source code)
outputs/

# Lab (POC experiments) - third-party clones, not tracked
lab/

# External / standalone
clients/
# But hook-dispatcher's internal/clients/ is real source code — keep it tracked.
!stations/hook-dispatcher/internal/clients/

# Backup files
*.bak

# Cronicle temp working dirs
vendor/cronicle/temp_*/

# Rigour
.metadata_never_index

# Rust build artifacts
stations/rlm/target/

# Voice-gateway binary models + WASM (managed externally)
stations/voice-gateway/models/
stations/voice-gateway/static/sherpa-onnx-wasm-kws-main.*

# Codex CLI working dir (per-machine config, not source)
.codex/

# Memvault debug captures (raw HTML response bodies from manual testing)
memvault_*.html

# Root-level scratch SQLite file (accidentally created by tools that default
# to ./workshop.db; canonical workshop DBs live under stations/*/data/)
/workshop.db
