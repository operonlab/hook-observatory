[
  {
    "name": "docvault_upload",
    "description": "上傳文件到 DocVault。tags 用逗號分隔。",
    "inputSchema": {
      "properties": {
        "title": {
          "title": "Title",
          "type": "string"
        },
        "content_hash": {
          "title": "Content Hash",
          "type": "string"
        },
        "source_type": {
          "default": "markdown",
          "title": "Source Type",
          "type": "string"
        },
        "source_uri": {
          "default": "",
          "title": "Source Uri",
          "type": "string"
        },
        "tags": {
          "default": "",
          "title": "Tags",
          "type": "string"
        }
      },
      "required": [
        "title",
        "content_hash"
      ],
      "title": "docvault_uploadArguments",
      "type": "object"
    },
    "outputSchema": {
      "properties": {
        "result": {
          "title": "Result",
          "type": "string"
        }
      },
      "required": [
        "result"
      ],
      "title": "docvault_uploadOutput",
      "type": "object"
    }
  },
