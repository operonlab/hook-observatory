{
  "name": "@workshop/ai-assistant",
  "version": "0.1.0",
  "description": "AI assistant floating widget — Web Component with SSE streaming chat",
  "type": "module",
  "main": "dist/ai-assistant.js",
  "module": "dist/ai-assistant.mjs",
  "types": "dist/ai-assistant.d.ts",
  "exports": {
    ".": {
      "types": "./dist/ai-assistant.d.ts",
      "import": "./dist/ai-assistant.mjs",
      "require": "./dist/ai-assistant.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@workshop/live2d-core": "workspace:*",
    "live2dcubismcore": "^1.0.2",
    "pixi.js": "^8.0.0",
    "untitled-pixi-live2d-engine": "^1.0.1"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "vite": "^6.4.2",
    "vite-plugin-dts": "^4.3.0"
  },
  "keywords": [
    "ai",
    "assistant",
    "web-component",
    "chat",
    "clippy"
  ],
  "license": "MIT",
  "pnpm": {
    "overrides": {
      "lodash": "^4.18.1",
      "lodash-es": "^4.18.1",
      "fast-uri": "^3.1.2",
      "picomatch": "^4.0.4",
      "serialize-javascript": "^7.0.5",
      "postcss": "^8.5.14",
      "brace-expansion": "^2.0.2",
      "@xmldom/xmldom": "^0.9.10",
      "@babel/plugin-transform-modules-systemjs": "^7.29.4"
    }
  }
}
