{
  "name": "@workshop/live2d-core",
  "version": "0.1.0",
  "description": "PixiJS-based layered sprite animator for Workshop AI assistant mascot",
  "type": "module",
  "main": "dist/live2d-core.js",
  "module": "dist/live2d-core.js",
  "types": "dist/live2d-core.d.ts",
  "exports": {
    ".": {
      "types": "./dist/live2d-core.d.ts",
      "import": "./dist/live2d-core.js"
    },
    "./cubism-entry": {
      "types": "./dist/cubism-entry.d.ts",
      "import": "./dist/cubism-entry.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "live2dcubismcore": "^1.0.2",
    "pixi.js": "^8.0.0",
    "untitled-pixi-live2d-engine": "^1.0.1"
  },
  "devDependencies": {
    "typescript": "^5.9.0",
    "vite": "^6.4.2",
    "vite-plugin-dts": "^4.3.0"
  },
  "keywords": [
    "sprite-animator",
    "pixi",
    "mascot",
    "ai-assistant",
    "rendering"
  ],
  "license": "MIT",
  "pnpm": {
    "overrides": {
      "gh-pages": "^5.0.0",
      "lodash": "^4.18.1",
      "lodash-es": "^4.18.1",
      "fast-uri": "^3.1.2",
      "picomatch": "^4.0.4",
      "serialize-javascript": "^7.0.5",
      "postcss": "^8.5.14",
      "brace-expansion": "^2.0.2",
      "@xmldom/xmldom": "^0.9.10",
      "@babel/plugin-transform-modules-systemjs": "^7.29.4"
    }
  }
}
