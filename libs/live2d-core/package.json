{
  "name": "@workshop/live2d-core",
  "version": "0.1.0",
  "description": "Platform-agnostic Live2D rendering core for Workshop AI assistant",
  "type": "module",
  "main": "dist/live2d-core.js",
  "module": "dist/live2d-core.mjs",
  "types": "dist/live2d-core.d.ts",
  "exports": {
    ".": {
      "types": "./dist/live2d-core.d.ts",
      "import": "./dist/live2d-core.mjs",
      "require": "./dist/live2d-core.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "pixi.js": "^8.0.0",
    "pixi-live2d-display": "latest"
  },
  "devDependencies": {
    "typescript": "^5.9.0",
    "vite": "^6.4.0",
    "vite-plugin-dts": "^4.3.0"
  },
  "keywords": [
    "live2d",
    "pixi",
    "mascot",
    "ai-assistant",
    "rendering"
  ],
  "license": "MIT"
}
