{
  "$schema": "quota-gate-policy-v1",
  "description": "Job execution authorization policy — max_level = highest degradation level at which the job is still allowed to run",
  "thresholds": {
    "L1": "CC_5h ≥ 60% OR GM_Pro ≥ 70%",
    "L2": "CC_5h ≥ 80% OR GM_Pro ≥ 85%",
    "L3": "CC_5h ≥ 95% OR GM_Pro ≥ 95%"
  },
  "jobs": {
    "daily-briefing": {
      "max_level": 0,
      "providers": ["gm", "cc"],
      "desc": "每日情報簡報 (~30-50K tokens)"
    },
    "ws-sysmon-weekly": {
      "max_level": 0,
      "providers": ["gm"],
      "desc": "系統監控週報 (~2K tokens)"
    },
    "ws-sysmon-monthly": {
      "max_level": 0,
      "providers": ["gm"],
      "desc": "系統監控月報 (~2K tokens)"
    },
    "ws-memvault-synthesis": {
      "max_level": 1,
      "providers": ["gm"],
      "desc": "知識圖譜合成 (~22-60K tokens)"
    },
    "ws-intelligence-digest": {
      "max_level": 1,
      "providers": ["gm", "cc"],
      "desc": "情報週報"
    },
    "ws-memvault-extract": {
      "max_level": 2,
      "providers": ["gm"],
      "desc": "記憶萃取 (~5-15K tokens)"
    },
    "ws-session-archive": {
      "max_level": 3,
      "providers": [],
      "desc": "Session 歸檔 (本地 oMLX，永遠執行)"
    },
    "ws-skill-lifecycle": {
      "max_level": 3,
      "providers": [],
      "desc": "Skill 生命週期 (無 LLM，永遠執行)"
    }
  }
}
