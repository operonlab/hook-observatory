# Copy this file to `.env` and tweak. `docker compose` reads `.env`
# automatically. Required: SESSION_CHANNEL_KEY should be changed from the
# default before exposing the service to anyone else on your machine.
#
# Generate a strong key:
#   openssl rand -hex 32

SESSION_CHANNEL_KEY=change-me-in-production

# Pin to a specific release (e.g. 0.2.0) for reproducible deploys.
SESSION_CHANNEL_VERSION=latest

# Service log verbosity. Examples: error | warn | info | debug | trace
RUST_LOG=info
