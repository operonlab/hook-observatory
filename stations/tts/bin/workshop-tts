#!/usr/bin/env bash
# workshop-tts launcher — use station venv + sdk-client on PYTHONPATH.
# Symlink into ~/.local/bin/ at deploy time:
#   ln -sf /Users/joneshong/workshop/stations/tts/bin/workshop-tts ~/.local/bin/workshop-tts

set -euo pipefail

HERE="$(cd "$(dirname "$0")/.." && pwd)"
PYTHON="${WORKSHOP_TTS_PYTHON:-$HERE/.venv/bin/python3}"
if [ ! -x "$PYTHON" ]; then
  PYTHON="$HOME/.local/bin/python3"
fi

export PYTHONPATH="$HERE:$HERE/../../libs/sdk-client:${PYTHONPATH:-}"

exec "$PYTHON" -m cli.tts "$@"
