{
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--user-data-dir",
        "/Users/joneshong/.playwright-profiles/agent-1",
        "--executable-path",
        "/Users/joneshong/Library/Caches/ms-playwright/chromium-1208/chrome-mac-arm64/Google Chrome for Testing.app/Contents/MacOS/Google Chrome for Testing"
      ]
    },
    "workshop-finance": {
      "command": "/Users/joneshong/workshop/.venv/bin/python3",
      "args": [
        "/Users/joneshong/workshop/mcp/finance/server.py"
      ],
      "env": {
        "CORE_API_URL": "http://localhost:8801",
        "FINANCE_SPACE_ID": "default"
      }
    },
    "playwright-2": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--user-data-dir",
        "/Users/joneshong/.playwright-profiles/agent-2",
        "--executable-path",
        "/Users/joneshong/Library/Caches/ms-playwright/chromium-1208/chrome-mac-arm64/Google Chrome for Testing.app/Contents/MacOS/Google Chrome for Testing",
        "--image-responses=omit"
      ]
    },
    "deepwiki": {
      "url": "https://mcp.deepwiki.com/mcp",
      "type": "http"
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "sandbox-executor": {
      "command": "/Users/joneshong/.local/bin/python3",
      "args": [
        "/Users/joneshong/workshop/mcp/sandbox/server.py"
      ],
      "env": {
        "PYTHON_PATH": "/Users/joneshong/.local/bin/python3"
      }
    },
    "hook-observatory": {
      "command": "/Users/joneshong/.local/bin/python3",
      "args": [
        "/Users/joneshong/workshop/mcp/hook-observatory/server.py"
      ]
    },
    "memvault": {
      "command": "/opt/homebrew/bin/uv",
      "args": [
        "run",
        "--no-project",
        "--with",
        "mcp>=1.0",
        "--with",
        "httpx>=0.27",
        "python3",
        "/Users/joneshong/workshop/mcp/memvault/server.py"
      ],
      "env": {
        "CORE_API_URL": "http://localhost:8801",
        "MEMVAULT_SPACE_ID": "default",
        "PYTHONIOENCODING": "utf-8"
      }
    },
    "pencil": {
      "command": "/Applications/Pencil.app/Contents/Resources/app.asar.unpacked/out/mcp-server-darwin-arm64",
      "args": [
        "--app",
        "desktop"
      ]
    },
    "tmux-relay": {
      "command": "/Users/joneshong/.local/bin/python3",
      "args": [
        "/Users/joneshong/workshop/mcp/tmux-relay/server.py"
      ],
      "env": {
        "PYTHONIOENCODING": "utf-8"
      }
    },
    "agent-metrics": {
      "command": "/Users/joneshong/.local/bin/python3",
      "args": [
        "/Users/joneshong/workshop/mcp/agent-metrics/server.py"
      ],
      "env": {
        "PYTHONIOENCODING": "utf-8"
      }
    }
  }
}