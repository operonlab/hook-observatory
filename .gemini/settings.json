{
  "mcpServers": {
    "deepwiki": {
      "url": "https://mcp.deepwiki.com/mcp",
      "type": "http"
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--user-data-dir",
        "/Users/joneshong/.playwright-profiles/agent-1",
        "--executable-path",
        "/Users/joneshong/Library/Caches/ms-playwright/chromium-1208/chrome-mac-arm64/Google Chrome for Testing.app/Contents/MacOS/Google Chrome for Testing"
      ]
    },
    "workshop-finance": {
      "command": "/Users/joneshong/Claude/shared/.venv/bin/python",
      "args": [
        "-m",
        "finance.mcp"
      ],
      "env": {
        "FINANCE_API_URL": "http://localhost:8793",
        "PYTHONPATH": "/Users/joneshong/Claude/services/finance/src:/Users/joneshong/Claude/shared/src"
      }
    },
    "workshop-muse": {
      "command": "/Users/joneshong/Claude/shared/.venv/bin/python",
      "args": [
        "-m",
        "muse.mcp"
      ],
      "env": {
        "MUSE_API_URL": "http://localhost:8794",
        "PYTHONPATH": "/Users/joneshong/Claude/services/muse/src:/Users/joneshong/Claude/shared/src"
      }
    },
    "workshop-quest": {
      "command": "/Users/joneshong/Claude/shared/.venv/bin/python",
      "args": [
        "-m",
        "quest.mcp"
      ],
      "env": {
        "QUEST_API_URL": "http://localhost:8797",
        "PYTHONPATH": "/Users/joneshong/Claude/services/quest/src:/Users/joneshong/Claude/shared/src"
      }
    },
    "sandbox-executor": {
      "command": "node",
      "args": [
        "/Users/joneshong/Claude/projects/sandbox-executor/dist/index.js"
      ],
      "env": {
        "PYTHON_PATH": "/Users/joneshong/.local/bin/python3"
      }
    },
    "playwright-2": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest",
        "--user-data-dir",
        "/Users/joneshong/.playwright-profiles/agent-2",
