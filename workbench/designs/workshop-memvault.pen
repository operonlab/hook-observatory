                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "x28Gt",
                      "name": "detContent",
                      "fill": "#a6adc8",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "非同步程式設計的核心不僅是技術實現，更是一種思維模式的轉變。從阻塞式到事件驅動，從線性到並行，理解這個轉變需要同時掌握底層的事件循環機制與高層的 async/await 抽象。\n\n在實際專案中，關鍵是辨識哪些操作適合非同步化（I/O 密集型），哪些不適合（CPU 密集型），以及如何設計錯誤處理與取消機制來確保系統穩定性。",
                      "lineHeight": 1.7,
                      "fontFamily": "Inter",
                      "fontSize": 13
                    },
